# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/postgres

# WB API Environment: "sandbox" или "production"
WB_ENV=production

# Интервал синхронизации (минуты)
SYNC_INTERVAL_MINUTES=1440

# Глубина выгрузки данных (месяцы)
DATA_RETENTION_MONTHS=3

# Максимум дней в одном запросе к WB API
WB_API_MAX_DAYS_PER_REQUEST=31

# Пауза между запросами при 429 (секунды)
WB_API_RETRY_DELAY=30

# Логирование: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=DEBUG

# Максимальное общее количество потоков для всех задач
MAX_TOTAL_WORKERS=15

# Максимум потоков на один тип задачи (отчёты / воронка / реклама)
MAX_WORKERS_PER_TASK_TYPE=5

# Максимум одновременных задач для одного пользователя
MAX_WORKERS_PER_USER=3

PARALLEL_USER_TASKS=true

ENCRYPTION_KEY=test
